# ──────────────────────────────────────────────
# EVM Tracker — Variables de entorno
# ──────────────────────────────────────────────
# Copiar este archivo como .env y ajustar los valores.
#   cp .env.example .env
# ──────────────────────────────────────────────

# Conexión a PostgreSQL
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/evm_tracker

# Orígenes permitidos para CORS (separados por coma si son varios)
CORS_ORIGINS=http://localhost:5173
